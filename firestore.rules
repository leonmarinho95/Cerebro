rules_version = '2';

// Regras de segurança do Firestore.
// Princípio: um usuário autenticado só pode ler/escrever sob o próprio
// users/{uid} e todas as subcoleções abaixo dele. Nada mais é acessível.
// Aplique no Console do Firebase → Firestore → Regras, ou via Firebase CLI.

service cloud.firestore {
  match /databases/{database}/documents {

    // Documento do usuário e tudo aninhado (notes, tasks, projects,
    // routines/{id}/entries, tags, goals, timelineEvents...).
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Bloqueia qualquer outro caminho por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
